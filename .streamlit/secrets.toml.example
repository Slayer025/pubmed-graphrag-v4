# Example Streamlit secrets. Copy this file to `.streamlit/secrets.toml` and fill
# in real values. Never commit the filled-in file.

[llm]
# openai = "sk-..."

[embedding]
# Provider: "local", "huggingface_api", or "remote_http"
provider = "local"

# HuggingFace Inference API token (required when provider = "huggingface_api")
hf_api_token = ""

# Custom remote embedding endpoint (required when provider = "remote_http")
service_url = ""

# Model identifier sent to the provider; must match the dimension configured
# in the local AppConfig (embedding_dim).
model = "sentence-transformers/all-MiniLM-L6-v2"

# Embedding API timeout in seconds
# timeout_seconds = 30

[app]
# Base URL for downloading release artifacts (e.g. GitHub release assets)
# artifact_base_url = "https://github.com/<owner>/<repo>/releases/download/v2.1-hnsw"
